{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowFastAPIAccessOnly",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::123456789012:role/FastAPIRuntimeRole"
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::agrovision-scans-bucket/*"
    }
  ]
}
